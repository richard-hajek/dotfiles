[[ $- != *i* ]] && return

[[ $ZSHRC_SOURCED == 1 ]] && return
ZSHRC_SOURCED=1

echo "Sourcing ~/.zshrc"

autoload -Uz compinit
compinit -d ~/.cache/zsh/zcompdump-$ZSH_VERSION

# First do ohmyzsh, it overwrites a lot of options
source ~/.config/zshrc_ohmyzsh
source ~/.config/shellrc
# source ~/.config/shellrc_aliases # fucking ohmyzsh overwrites aliases

# When tab completing ignore case
# When tab completing interchange -_
zstyle ':completion:*' matcher-list 'm:{a-zA-Z}={A-Za-z}' '+m:[-_]=[-_]'

# These names are case insensitive and underscores are ignored.
setopt COMPLETE_ALIASES
# > Prevents aliases on the command line from being internally substituted before completion is attempted.  The effect is to make the alias a distinct command for completion purposes.
setopt SHARE_HISTORY

# Fancy --help
if hash bat &> /dev/null; then

  function bathelp() {

    if [[ $# > 0 ]]; then
      echo "Bad use of global --help alias detected! Please use \\--help instead, optionally adding | bathelp manually"
      return
    fi

    bat --language=help --style=plain
  }

  alias -g -- -h='-h 2>&1 | bathelp'
  alias -g -- --help='--help 2>&1 | bathelp'
fi

# No idea what this is doing 
zstyle ':completion:*' completer _expand_alias _complete _ignored

if [ -e /home/meowxiik/.nix-profile/etc/profile.d/nix.sh ]; then . /home/meowxiik/.nix-profile/etc/profile.d/nix.sh; fi # added by Nix installer

# bun completions
[ -s "/home/rhajek/.bun/_bun" ] && source "/home/rhajek/.bun/_bun"

# bun
export BUN_INSTALL="$HOME/.bun"
export PATH="$BUN_INSTALL/bin:$PATH"

# bum
export BUM_INSTALL="$HOME/.bum"
export PATH="$BUM_INSTALL/bin:$PATH"



